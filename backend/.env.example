# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/nandibaag

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL_PRIMARY=meta-llama/llama-3.3-70b-instruct:free
# NOTE: Fallback models (FALLBACK_1, FALLBACK_2, etc.) are no longer configured here.
# They are hardcoded in aiService.js as a 7-model chain across 6 providers:
# Qwen 80B, NVIDIA 120B, OpenAI 120B, Google Gemma 31B, NousResearch 405B, Tencent Hy3.
# All are free-tier and use the same OPENROUTER_API_KEY.

# Server Configuration
PORT=7000
NODE_ENV=development

# Resort Contact Numbers (for WhatsApp bot)
RESORT_CONTACT_1=+919876543210
RESORT_CONTACT_2=+919876543211
RESORT_CONTACT_3=+919876543212

# Default Admin Credentials (change these in production)
ADMIN_DEFAULT_EMAIL=admin@nandibaag.com
ADMIN_DEFAULT_PASSWORD=change-this-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:7001

# Google Gemini Tier Configuration (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq Tier Configuration (production tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Cloudflare Workers AI Configuration (optional)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# Cerebras AI Configuration (optional)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gemma-4-31b

# Ollama Configuration (local dev/testing ONLY - never in production)
AI_TEST_MODE=false
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# REMOVED: Blueminds Tier Configuration
# BLUEMINDS_API_KEY=
# BLUEMINDS_MODEL=gpt-4o-mini
# BLUEMINDS_BASE_URL=https://api.bluesminds.com/v1
# NOTE: Blueminds was removed from the AI provider fallback chain because diagnostics
# confirmed their gateway serves stale cached responses (dated March 2023) keyed on
# the customer message string. This bypassed our system prompt and context, presenting
# a critical data-integrity and business logic bypass risk.
